    {
      "parameters": {
        "jsCode": "const invoice = $json.processInvoiceModel || {};\n\n// --------------------\n// RAW\n// --------------------\nconst rawText = JSON.stringify(invoice || {});\n\n// --------------------\n// CORE FIELDS\n// --------------------\nconst invoice_number =\n  invoice.invoiceNumber ||\n  invoice.invoice_number ||\n  \"\";\n\nconst vendor_name =\n  invoice.vendorName ||\n  invoice.vendor_name ||\n  \"\";\n\nconst invoice_date =\n  invoice.invoiceDate ||\n  invoice.invoice_date ||\n  \"\";\n\nconst due_date =\n  invoice.paymentDeadline ||\n  invoice.due_date ||\n  \"\";\n\n// --------------------\n// VENDOR ADDRESS\n// --------------------\nconst vendor_address =\n  (invoice.vendorAddress || invoice.vendor_address || \"\")\n    .toString()\n    .replace(/\\n/g, \", \")\n    .trim();\n\n// --------------------\n// AMOUNTS\n// --------------------\nconst subtotal = invoice.subTotal || invoice.subtotal || 0;\nconst tax = invoice.totalTaxAmount || invoice.tax || 0;\nconst total_amount = invoice.total || invoice.totalAmount || 0;\n\n// --------------------\n// DISCOUNT\n// --------------------\nlet total_discount = 0;\n\nconst discountFields = [\n  invoice.discount,\n  invoice.totalDiscount,\n  invoice.discountAmount\n];\n\nfor (const d of discountFields) {\n  if (typeof d === \"number\") total_discount += d;\n}\n\n// fallback regex\nconst dm = rawText.match(/discount\\s*[:\\-]?\\s*([0-9.,]+)/i);\nif (!total_discount && dm) {\n  total_discount = parseFloat(dm[1].replace(/,/g, \"\"));\n}\n\n// --------------------\n// NOTES\n// --------------------\nconst notes =\n  invoice.notes ||\n  invoice.remarks ||\n  invoice.terms ||\n  (rawText.match(/(notes|remarks|terms|special notes)\\s*[:\\-]?\\s*([\\s\\S]{10,300})/i)?.[2] || \"\");\n\n// --------------------\n// CURRENCY (SAME LOGIC AS OCR)\n// --------------------\nlet currency = \"UNKNOWN\";\n\n// symbol\nif (rawText.includes(\"₹\")) currency = \"INR\";\nelse if (rawText.includes(\"$\")) currency = \"USD\";\nelse if (rawText.includes(\"€\")) currency = \"EUR\";\nelse if (rawText.includes(\"£\")) currency = \"GBP\";\n\n// country/address\nconst address = ((vendor_address || \"\") + \" \" + rawText).toUpperCase();\n\nif (currency === \"UNKNOWN\") {\n  const map = {\n    INDIA: \"INR\",\n    USA: \"USD\",\n    \"UNITED STATES\": \"USD\",\n    UK: \"GBP\",\n    \"UNITED KINGDOM\": \"GBP\",\n    CANADA: \"CAD\",\n    GERMANY: \"EUR\",\n    EUROPE: \"EUR\",\n    FRANCE: \"EUR\"\n  };\n\n  for (const key in map) {\n    if (address.includes(key)) {\n      currency = map[key];\n      break;\n    }\n  }\n}\n\nif (currency === \"UNKNOWN\") currency = \"USD\";\n\n//------------------\n// Bill in name of \n//------------------\nconst bill_to =\n  invoice.billTo ||\n  invoice.bill_to ||\n  \"\";\n\n// --------------------\n// OUTPUT (SAME SCHEMA AS OCR)\n// --------------------\nreturn [{\n  json: {\n    invoice_number,\n    vendor_name,\n    vendor_address,\n    invoice_date,\n    due_date,\n    subtotal,\n    tax,\n    total_amount,\n    total_discount,\n    notes,\n    currency,\n    bill_to,\n    source: \"pdf\"\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
