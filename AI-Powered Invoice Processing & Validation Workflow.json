    {
      "parameters": {
        "jsCode": "const invoice = $json;\n\nlet status = \"Valid\";\nlet validation_reason = \"\";\n\nif (!invoice.invoice_number) {\n  status = \"Require_Verification\";\n  validation_reason = \"Missing invoice number\";\n}\n\nif (!invoice.vendor_name) {\n  status = \"Require_Verification\";\n  validation_reason = \"Missing vendor\";\n}\n\nif (!invoice.total_amount || Number(invoice.total_amount) <= 0) {\n  status = \"Require_Verification\";\n  validation_reason = \"Invalid total amount\";\n}\n\nreturn [{\n  json: {\n    ...invoice,\n    status,\n    validation_reason\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2096,
        -1440
      ],
      "id": "0172e570-b7bc-4e85-9d49-727f1a9cb697",
      "name": "Validation1"
    },
    {
      "parameters": {
        "jsCode": "const invoice = $('Validation1').item.json; // or merged invoice object\n\nconst rows = $input.all().map(i => i.json);\n\nconst duplicate = rows.some(r =>\n  r.vendor_name === invoice.vendor_name &&\n  Number(r.total_amount) === Number(invoice.total_amount)\n);\n\nreturn [{\n  json: {\n    ...invoice,\n    isDuplicate: duplicate\n  }\n}];"
      },
