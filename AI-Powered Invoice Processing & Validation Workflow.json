    {
      "parameters": {
        "jsCode": "const ocr = $json[0] || $json;\n\nconst text = ocr.extractedText || \"\";\n\n// --------------------\n// HELPERS\n// --------------------\nconst pick = (regex) => (text.match(regex)?.[1] || \"\").trim();\n\nconst pickAll = (regex) =>\n  [...text.matchAll(regex)].map(m => m[1]?.trim()).filter(Boolean);\n\n// --------------------\n// CORE FIELDS\n// --------------------\nconst invoice_number =\n  pick(/Invoice Reference:\\s*(.*)/i) ||\n  pick(/Invoice Number:\\s*(.*)/i);\n\nconst invoice_date = pick(/Date of Issue:\\s*(.*)/i);\nconst due_date = pick(/Due By:\\s*(.*)/i);\n\n// --------------------\n// VENDOR\n// --------------------\nconst vendor_name =\n  (text.match(/^(.{3,60})\\n.*(Invoice|Bill To|Invoice To)/im)?.[1] || \"\").trim();\n\nconst vendor_address =\n  (text.match(/(Vendor|Bill From|From)\\s*[:\\-]?\\s*([\\s\\S]{20,200}?)(Invoice To|Bill To|$)/i)?.[2] || \"\")\n    .replace(/\\n/g, \", \")\n    .replace(/\\s+/g, \" \")\n    .trim();\n\nconst bill_to =\n  (text.match(/(Bill To|Invoice To|Billed To)\\s*[:\\-]?\\s*([\\s\\S]{10,200}?)(\\n\\n|Total|Invoice|$)/i)?.[2] || \"\")\n    .replace(/\\n/g, \", \")\n    .replace(/\\s+/g, \" \")\n    .trim();\n\n// --------------------\n// AMOUNTS\n// --------------------\nconst money = (text.match(/[£₹$€]\\s?[\\d,]+(?:\\.\\d{1,2})?/g) || [])\n  .map(v => parseFloat(v.replace(/[^0-9.]/g, \"\")));\n\nconst subtotal = money[0] || 0;\nconst tax = money[1] || 0;\nconst total_amount = money.length ? money[money.length - 1] : 0;\n\n// --------------------\n// DISCOUNT\n// --------------------\nconst discounts =\n  pickAll(/Discount\\s*[:\\-]?\\s*([£₹$€]?\\s?[\\d,]+(?:\\.\\d{1,2})?)/gi)\n    .map(v => parseFloat(v.replace(/[^0-9.]/g, \"\")));\n\nconst total_discount = discounts.reduce((a, b) => a + b, 0);\n\n// --------------------\n// NOTES\n// --------------------\nconst notes =\n  pick(/(Notes|Remarks|Special Notes|Terms)\\s*[:\\-]?\\s*([\\s\\S]{10,300})/i) || \"\";\n\n// --------------------\n// CURRENCY DETECTION (SYMBOL + COUNTRY + ADDRESS)\n// --------------------\nlet currency = \"UNKNOWN\";\n\n// 1. SYMBOL (HIGHEST PRIORITY)\nif (text.includes(\"₹\")) currency = \"INR\";\nelse if (text.includes(\"$\")) currency = \"USD\";\nelse if (text.includes(\"€\")) currency = \"EUR\";\nelse if (text.includes(\"£\")) currency = \"GBP\";\n\n// 2. COUNTRY / ADDRESS KEYWORDS\nconst address = (vendor_address + \" \" + text).toUpperCase();\n\nif (currency === \"UNKNOWN\") {\n  const map = {\n    INDIA: \"INR\",\n    \"UNITED STATES\": \"USD\",\n    USA: \"USD\",\n    \"U.S.A\": \"USD\",\n    UK: \"GBP\",\n    \"UNITED KINGDOM\": \"GBP\",\n    CANADA: \"CAD\",\n    GERMANY: \"EUR\",\n    FRANCE: \"EUR\",\n    EUROPE: \"EUR\"\n  };\n\n  for (const key in map) {\n    if (address.includes(key)) {\n      currency = map[key];\n      break;\n    }\n  }\n}\n\n// fallback\nif (currency === \"UNKNOWN\") currency = \"USD\";\n\n// --------------------\n// OUTPUT\n// --------------------\nreturn [{\n  json: {\n    invoice_number,\n    vendor_name,\n    vendor_address,\n    bill_to,\n    invoice_date,\n    due_date,\n    subtotal,\n    tax,\n    total_amount,\n    total_discount,\n    notes,\n    currency,\n    source: \"ocr\"\n  }\n}];"
      },
