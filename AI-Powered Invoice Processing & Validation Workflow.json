      "parameters": {
        "jsCode": "const invoice = $('Validation').item.json;\n\n// normalize helper\nconst norm = (v) =>\n  (v ?? \"\")\n    .toString()\n    .replace(/,/g, \"\")\n    .trim()\n    .toLowerCase();\n\n// safe number\nconst num = (v) => Number(String(v).replace(/,/g, \"\")) || 0;\n\n// get rows safely\nconst rows = $input.all().map(i => i.json || {});\n\n// DEBUG (optional but useful)\n// console.log(rows);\n\nconst duplicate = rows.some(r =>\n  norm(r.vendor_name) === norm(invoice.vendor_name) &&\n  num(r.total_amount) === num(invoice.total_amount)\n);\n\nreturn [{\n  json: {\n    ...invoice,\n    isDuplicate: duplicate\n  }\n}];"
      },
